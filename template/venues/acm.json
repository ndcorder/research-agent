{
  "name": "ACM Conference (sigconf)",
  "id": "acm",
  "documentclass": "\\documentclass[sigconf,review,anonymous]{acmart}",
  "packages": [
    "\\usepackage{booktabs}",
    "\\usepackage{algorithm}",
    "\\usepackage{algpseudocode}",
    "\\usepackage{subcaption}"
  ],
  "bibliography_style": "ACM-Reference-Format",
  "citation_style": "natbib",
  "citation_commands": ["\\citep{}", "\\citet{}", "\\cite{}"],
  "page_limit": 12,
  "abstract_word_limit": 250,
  "blind_review": true,
  "sections": ["Introduction", "Related Work", "Methodology", "Evaluation", "Results", "Discussion", "Conclusion"],
  "notes": "ACM sigconf format. Uses acmart class. Double-blind by default. 12-page limit excluding refs. Requires CCS concepts and keywords. Use \\begin{CCSXML} and \\keywords{}."
}
