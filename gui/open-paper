#!/usr/bin/env bash
# open-paper - Launch the Research Agent GUI for a paper project
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_NAME="Research Agent"

usage() {
  echo "Usage: open-paper [<project-dir>]"
  echo ""
  echo "Launch the Research Agent GUI for a paper project."
  echo "If no directory is given, uses the current directory."
  echo ""
  echo "Options:"
  echo "  -h, --help    Show this help"
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

PROJECT_DIR="${1:-.}"
PROJECT_DIR="$(cd "$PROJECT_DIR" && pwd)"

if [ ! -f "$PROJECT_DIR/.paper.json" ]; then
  echo "Error: Not a paper project (no .paper.json found in $PROJECT_DIR)"
  echo "Create one with: create-paper <name> <topic>"
  exit 1
fi

# Look for the app binary in several locations
find_binary() {
  # 1. Built binary in the gui directory (dev)
  local dev_binary="$SCRIPT_DIR/src-tauri/target/release/research-agent-gui"
  if [ -x "$dev_binary" ]; then
    echo "$dev_binary"
    return
  fi

  # 2. macOS app bundle
  local app_bundle="$SCRIPT_DIR/src-tauri/target/release/bundle/macos/$APP_NAME.app/Contents/MacOS/$APP_NAME"
  if [ -x "$app_bundle" ]; then
    echo "$app_bundle"
    return
  fi

  # 3. Installed in PATH
  if command -v research-agent-gui &>/dev/null; then
    echo "research-agent-gui"
    return
  fi

  # 4. macOS /Applications
  local installed_app="/Applications/$APP_NAME.app/Contents/MacOS/$APP_NAME"
  if [ -x "$installed_app" ]; then
    echo "$installed_app"
    return
  fi

  return 1
}

BINARY=$(find_binary) || {
  echo "Error: Could not find Research Agent GUI binary."
  echo "Build it with: cd $SCRIPT_DIR && npm run tauri build"
  exit 1
}

echo "Opening $PROJECT_DIR..."
exec "$BINARY" -- --project-dir "$PROJECT_DIR" &
