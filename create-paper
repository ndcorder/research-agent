#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────────────────────
# create-paper — Stamp out a new research paper project and
#                optionally launch Claude Code to write it.
#
# Usage:
#   create-paper <directory> [topic] [--venue <venue>]
#
# Examples:
#   create-paper my-survey "A survey on LLM reasoning"
#   create-paper my-paper "Protein folding" --venue nature
#   create-paper ieee-paper --venue ieee
#
# Venues: generic, ieee, acm, neurips, nature, arxiv, apa
# ──────────────────────────────────────────────────────────────

# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/template"
VENUES_DIR="$TEMPLATE_DIR/venues"
SKILLS_REPO="https://github.com/K-Dense-AI/claude-scientific-skills.git"
PRAXIS_REPO="https://github.com/zmtsikriteas/praxis.git"

# ── Colors ────────────────────────────────────────────────────
bold='\033[1m'
green='\033[0;32m'
blue='\033[0;34m'
yellow='\033[0;33m'
red='\033[0;31m'
reset='\033[0m'

info()  { echo -e "${blue}→${reset} $*"; }
ok()    { echo -e "${green}✓${reset} $*"; }
warn()  { echo -e "${yellow}!${reset} $*"; }

# ── Parse arguments ──────────────────────────────────────────
if [[ $# -lt 1 ]]; then
    echo -e "${bold}Usage:${reset} create-paper <directory> [topic] [--venue <venue>]"
    echo ""
    echo "  <directory>  Name/path for the new paper project"
    echo "  [topic]      Paper topic — starts the writing pipeline"
    echo "  --venue      Target venue format (default: generic)"
    echo ""
    echo -e "${bold}Available venues:${reset}"
    echo "  generic   Standard journal article (default)"
    echo "  ieee      IEEE conference/journal (IEEEtran, numeric citations)"
    echo "  acm       ACM conference (acmart sigconf, double-blind)"
    echo "  neurips   NeurIPS/ICML/ICLR (neurips style, 9-page limit)"
    echo "  nature    Nature family journals (Results before Methods)"
    echo "  arxiv     arXiv preprint (no limits, extended format)"
    echo "  apa       APA 7th edition (psychology/social sciences)"
    echo ""
    echo "Examples:"
    echo "  create-paper my-survey \"A survey on LLM reasoning\""
    echo "  create-paper my-paper \"Protein folding\" --venue nature"
    exit 1
fi

TARGET="$1"
shift

TOPIC=""
VENUE="generic"

# Parse remaining args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --venue|-v)
            VENUE="$2"
            shift 2
            ;;
        *)
            TOPIC="$1"
            shift
            ;;
    esac
done

if [[ -e "$TARGET" ]]; then
    echo -e "${red}✗${reset} '$TARGET' already exists." >&2
    exit 1
fi

# Validate venue
if [[ ! -f "$VENUES_DIR/$VENUE.json" ]]; then
    echo -e "${red}✗${reset} Unknown venue '$VENUE'. Available: generic, ieee, acm, neurips, nature, arxiv, apa" >&2
    exit 1
fi

# Check dependencies
for cmd in git pdflatex claude; do
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "${red}✗${reset} '$cmd' is required but not found in PATH." >&2
        exit 1
    fi
done

# ── Read venue config ─────────────────────────────────────────
VENUE_NAME=$(python3 -c "import json; print(json.load(open('$VENUES_DIR/$VENUE.json'))['name'])")
VENUE_DOCCLASS=$(python3 -c "import json; print(json.load(open('$VENUES_DIR/$VENUE.json'))['documentclass'])")
VENUE_BIBSTYLE=$(python3 -c "import json; print(json.load(open('$VENUES_DIR/$VENUE.json'))['bibliography_style'])")
VENUE_ABSTRACT_LIMIT=$(python3 -c "import json; print(json.load(open('$VENUES_DIR/$VENUE.json'))['abstract_word_limit'])")
VENUE_SECTIONS=$(python3 -c "import json; v=json.load(open('$VENUES_DIR/$VENUE.json')); print('\n'.join(v['sections']))")

info "Creating ${bold}$VENUE_NAME${reset} paper in ${bold}$TARGET${reset}"

# ── Create project ────────────────────────────────────────────
mkdir -p "$TARGET"
cd "$TARGET"

# Generate main.tex from venue config
python3 - "$VENUES_DIR/$VENUE.json" <<'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    v = json.load(f)

lines = [v["documentclass"]]
for pkg in v["packages"]:
    lines.append(pkg)

lines.append("")
lines.append("\\hypersetup{")
lines.append("  colorlinks=true,")
lines.append("  linkcolor=blue!70!black,")
lines.append("  citecolor=green!50!black,")
lines.append("  urlcolor=blue!80!black")
lines.append("}")
lines.append("")
lines.append("\\title{Your Paper Title Here}")
lines.append("\\author{")
lines.append("  First Author\\textsuperscript{1} \\and")
lines.append("  Second Author\\textsuperscript{2} \\\\\\\\")
lines.append("  \\textsuperscript{1}Department, University \\\\\\\\")
lines.append("  \\textsuperscript{2}Department, University \\\\\\\\")
lines.append("  \\texttt{email@example.com}")
lines.append("}")
lines.append("\\date{\\today}")
lines.append("")
lines.append("\\begin{document}")
lines.append("")
lines.append("\\maketitle")
lines.append("")
lines.append("\\begin{abstract}")
lines.append("% TODO: Write abstract (limit: " + str(v["abstract_word_limit"]) + " words)")
lines.append("\\end{abstract}")
lines.append("")

for section in v["sections"]:
    lines.append("\\section{" + section + "}")
    lines.append("% TODO: Write " + section + " section")
    lines.append("")

lines.append("\\bibliographystyle{" + v["bibliography_style"] + "}")
lines.append("\\bibliography{references}")
lines.append("")
lines.append("\\end{document}")

with open("main.tex", "w") as f:
    f.write("\n".join(lines) + "\n")
PYEOF
ok "main.tex generated ($VENUE_NAME format)"

# Copy other template files
cp "$TEMPLATE_DIR/references.bib" .
cp "$TEMPLATE_DIR/gitignore" .gitignore
mkdir -p .claude/commands figures attachments research/sources
cp "$TEMPLATE_DIR/claude/CLAUDE.md" .claude/
cp "$TEMPLATE_DIR/claude/settings.local.json" .claude/
cp "$TEMPLATE_DIR/claude/commands/"*.md .claude/commands/

# Copy venue config for reference
cp "$VENUES_DIR/$VENUE.json" .venue.json
ok "Template files copied"

# Generate .paper.json config
python3 -c "
import json
config = {
    'topic': '''${TOPIC}''' if '''${TOPIC}''' else '',
    'venue': '$VENUE',
    'depth': 'standard',
    'model': 'claude-sonnet-4-6',
    'max_revisions': 3,
    'authors': [
        {
            'name': 'First Author',
            'affiliation': 'Department, University',
            'email': 'author@example.com',
            'orcid': ''
        }
    ],
    'keywords': [],
    'funding': '',
    'conflicts': '',
    'data_availability': '',
    'code_availability': ''
}
json.dump(config, open('.paper.json', 'w'), indent=2)
"
ok "Paper config written (.paper.json)"

# Initialize git
git init -q
ok "Git initialized"

# Add scientific skills submodule (shallow clone for speed)
info "Cloning 177 scientific skills (shallow)..."
git submodule add --depth 1 "$SKILLS_REPO" vendor/claude-scientific-skills 2>&1 | grep -v "^$"
ok "Skills submodule added"

# Symlink skills into .claude/skills
ln -s "$(pwd)/vendor/claude-scientific-skills/scientific-skills" .claude/skills
ok "Skills linked to .claude/skills"

# Set up codex-bridge if available (optional sister project)
if command -v codex-bridge &>/dev/null; then
    codex-bridge init &>/dev/null
    # Merge the codex .mcp.json into our project (it creates its own)
    ok "Codex Bridge configured (adversarial AI reviewer)"
else
    info "codex-bridge not found — skipping (install for adversarial AI review)"
fi

# Set up Praxis scientific analysis toolkit (optional)
info "Setting up Praxis scientific analysis toolkit..."
git submodule add --depth 1 "$PRAXIS_REPO" vendor/praxis 2>&1 | grep -v "^$"
if [[ -d vendor/praxis ]]; then
    # Symlink Praxis as a skill
    ln -s "$(pwd)/vendor/praxis" .claude/skills/praxis
    # Install Praxis Python dependencies
    if python3 -m pip install -q numpy scipy pandas matplotlib lmfit peakutils openpyxl uncertainties 2>/dev/null; then
        ok "Praxis installed (50+ characterisation techniques, 9 journal styles)"
    else
        ok "Praxis linked (run 'pip install -r vendor/praxis/requirements.txt' to enable analysis)"
    fi
else
    warn "Praxis clone failed — skipping (figures and analysis still work via matplotlib)"
fi

# Initial commit (skip GPG signing for bootstrap — it's local-only)
git add -A
git -c commit.gpgsign=false commit -q -m "Initial paper project ($VENUE_NAME format)"
ok "Initial commit created"

# Verify LaTeX compiles
info "Verifying LaTeX compilation..."
if latexmk -pdf -interaction=nonstopmode main.tex &>/dev/null; then
    ok "LaTeX compiles successfully"
    latexmk -c &>/dev/null
else
    warn "LaTeX compilation had issues (you can fix them with /compile)"
fi

# ── Configuration TUI ────────────────────────────────────────
CFG_TOPIC="$TOPIC"
CFG_VENUE="$VENUE"
CFG_VENUE_NAME="$VENUE_NAME"
CFG_DEPTH="standard"

ALL_VENUES=("generic" "ieee" "acm" "neurips" "nature" "arxiv" "apa")
ALL_VENUE_NAMES=("Standard journal article" "IEEE conference/journal" "ACM conference" "NeurIPS/ICML/ICLR" "Nature family" "arXiv preprint" "APA 7th edition")

# What each depth level means (read-only display)
std_agents="5"               ; deep_agents="12 (specialized)"
std_refs="30-50"             ; deep_refs="60-80"
std_second="no"              ; deep_second="yes — thesis-informed"
std_seclit="no"              ; deep_seclit="yes — per-section deep-dives"
std_qa="5"                   ; deep_qa="8"
std_codex="1× per checkpoint"; deep_codex="2× at key checkpoints"

SELECTED=0
FIELDS=3  # topic, venue, depth

get_venue_index() {
    for i in "${!ALL_VENUES[@]}"; do
        [[ "${ALL_VENUES[$i]}" == "$CFG_VENUE" ]] && echo "$i" && return
    done
    echo 0
}

draw_tui() {
    local d="$CFG_DEPTH"
    local vi
    vi=$(get_venue_index)

    tput cup 0 0
    tput ed

    local w=57
    printf "${bold}┌─ Paper Configuration "
    printf '─%.0s' $(seq 1 34)
    printf "┐${reset}\n"
    printf "${bold}│${reset}%${w}s${bold}│${reset}\n" ""

    # Topic
    if [[ $SELECTED -eq 0 ]]; then
        printf "${bold}│${reset}  ${green}▸ Topic${reset}       ${bold}%-44s${reset}${bold}│${reset}\n" "$CFG_TOPIC"
    else
        printf "${bold}│${reset}    Topic       %-44s${bold}│${reset}\n" "$CFG_TOPIC"
    fi

    # Venue
    local venue_display="$CFG_VENUE  ·  ${ALL_VENUE_NAMES[$vi]}"
    if [[ $SELECTED -eq 1 ]]; then
        printf "${bold}│${reset}  ${green}▸ Venue${reset}       ${bold}%-44s${reset}${bold}│${reset}\n" "$venue_display"
    else
        printf "${bold}│${reset}    Venue       %-44s${bold}│${reset}\n" "$venue_display"
    fi

    # Depth
    local depth_display
    if [[ "$d" == "standard" ]]; then
        depth_display="● standard        ○ deep"
    else
        depth_display="○ standard        ● deep"
    fi
    if [[ $SELECTED -eq 2 ]]; then
        printf "${bold}│${reset}  ${green}▸ Depth${reset}       ${bold}%-44s${reset}${bold}│${reset}\n" "$depth_display"
    else
        printf "${bold}│${reset}    Depth       %-44s${bold}│${reset}\n" "$depth_display"
    fi

    printf "${bold}│${reset}%${w}s${bold}│${reset}\n" ""

    # Info section
    printf "${bold}│${reset}  ── What ${bold}%-47s${reset}${bold}│${reset}\n" "${d} means ──"

    # Read-only stats
    local agents refs second seclit qa codex
    if [[ "$d" == "deep" ]]; then
        agents="$deep_agents"; refs="$deep_refs"; second="$deep_second"
        seclit="$deep_seclit"; qa="$deep_qa"; codex="$deep_codex"
    else
        agents="$std_agents"; refs="$std_refs"; second="$std_second"
        seclit="$std_seclit"; qa="$std_qa"; codex="$std_codex"
    fi

    printf "${bold}│${reset}  Research agents:       %-32s${bold}│${reset}\n" "$agents"
    printf "${bold}│${reset}  Reference target:      %-32s${bold}│${reset}\n" "$refs"
    printf "${bold}│${reset}  Second research pass:  %-32s${bold}│${reset}\n" "$second"
    printf "${bold}│${reset}  Section lit searches:  %-32s${bold}│${reset}\n" "$seclit"
    printf "${bold}│${reset}  Max QA iterations:     %-32s${bold}│${reset}\n" "$qa"
    printf "${bold}│${reset}  Codex rounds:          %-32s${bold}│${reset}\n" "$codex"

    printf "${bold}│${reset}%${w}s${bold}│${reset}\n" ""
    printf "${bold}│${reset}  ${blue}[↑↓]${reset} Navigate  ${blue}[←→]${reset} Change  ${blue}[Enter]${reset} Launch        ${bold}│${reset}\n"
    printf "${bold}│${reset}  ${blue}[e]${reset}  Edit topic  ${blue}[q]${reset}  Quit                       ${bold}│${reset}\n"
    printf "${bold}└"
    printf '─%.0s' $(seq 1 $w)
    printf "┘${reset}\n"
}

cycle_field() {
    local dir=$1
    case $SELECTED in
        1)  # Venue
            local vi
            vi=$(get_venue_index)
            local len=${#ALL_VENUES[@]}
            vi=$(( (vi + dir + len) % len )) || true
            CFG_VENUE="${ALL_VENUES[$vi]}"
            CFG_VENUE_NAME="${ALL_VENUE_NAMES[$vi]}"
            ;;
        2)  # Depth
            if [[ "$CFG_DEPTH" == "standard" ]]; then
                CFG_DEPTH="deep"
            else
                CFG_DEPTH="standard"
            fi
            ;;
    esac
}

run_tui() {
    # Disable set -e for the TUI — interactive read loops return non-zero
    # on timeouts, escape sequences, and empty input, which kills the script
    set +e

    tput civis  # hide cursor
    tput clear
    trap 'tput cnorm; tput clear; set -e' EXIT INT TERM

    draw_tui

    while true; do
        IFS= read -rsn1 key

        case "$key" in
            $'\x1b')  # Escape sequence (arrow keys)
                read -rsn2 -t 0.1 seq
                case "$seq" in
                    '[A') SELECTED=$(( SELECTED > 0 ? SELECTED - 1 : FIELDS - 1 )) ;;
                    '[B') SELECTED=$(( SELECTED < FIELDS - 1 ? SELECTED + 1 : 0 )) ;;
                    '[C') cycle_field 1 ;;
                    '[D') cycle_field -1 ;;
                esac
                ;;
            '')  # Enter — launch
                tput cnorm
                tput clear
                set -e
                return 0
                ;;
            'q'|'Q')
                tput cnorm
                tput clear
                echo "Aborted."
                exit 0
                ;;
            'e'|'E')
                if [[ $SELECTED -eq 0 ]]; then
                    tput cnorm
                    tput cup 20 0
                    echo -ne "  New topic: "
                    read -r new_topic
                    if [[ -n "$new_topic" ]]; then
                        CFG_TOPIC="$new_topic"
                    fi
                    tput civis
                fi
                ;;
        esac

        draw_tui
    done
}

# ── Run TUI (only if interactive terminal) ────────────────────
if [[ -t 0 ]]; then
    run_tui
fi

# ── Write final config ────────────────────────────────────────
python3 -c "
import json, os
config = json.load(open('.paper.json')) if os.path.exists('.paper.json') else {}
config['topic'] = '''${CFG_TOPIC}'''
config['venue'] = '${CFG_VENUE}'
config['depth'] = '${CFG_DEPTH}'
json.dump(config, open('.paper.json', 'w'), indent=2)
"

# Update venue config if changed
if [[ "$CFG_VENUE" != "$VENUE" ]]; then
    cp "$VENUES_DIR/$CFG_VENUE.json" .venue.json
    ok "Venue updated to $CFG_VENUE_NAME"
fi

TOPIC="$CFG_TOPIC"

echo -e "${bold}Paper project ready!${reset}"
echo ""
echo "  Project:  $(pwd)"
echo "  Venue:    $CFG_VENUE_NAME"
echo "  Depth:    $CFG_DEPTH"
echo ""

if [[ -n "$TOPIC" ]]; then
    read -p "Launch autonomous pipeline now? [Y/n] " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        exec "$SCRIPT_DIR/write-paper"
    fi
else
    info "Launch when ready:"
    echo ""
    echo "  ${bold}Autonomous:${reset}  cd $(pwd) && write-paper \"your topic\""
    echo "  ${bold}Interactive:${reset} cd $(pwd) && claude"
fi
