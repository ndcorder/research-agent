#!/usr/bin/env bash
set -euo pipefail

# ──────────────────────────────────────────────────────────────
# create-paper — Stamp out a new research paper project and
#                optionally launch Claude Code to write it.
#
# Usage:
#   create-paper <directory> [topic] [--venue <venue>]
#
# Examples:
#   create-paper my-survey "A survey on LLM reasoning"
#   create-paper my-paper "Protein folding" --venue nature
#   create-paper ieee-paper --venue ieee
#
# Venues: generic, ieee, acm, neurips, nature, arxiv, apa
# ──────────────────────────────────────────────────────────────

# Resolve symlinks to find the real script location
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/template"
VENUES_DIR="$TEMPLATE_DIR/venues"
SKILLS_REPO="https://github.com/K-Dense-AI/claude-scientific-skills.git"
PRAXIS_REPO="https://github.com/zmtsikriteas/praxis.git"

# ── Colors ────────────────────────────────────────────────────
bold='\033[1m'
green='\033[0;32m'
blue='\033[0;34m'
yellow='\033[0;33m'
red='\033[0;31m'
reset='\033[0m'

info()  { echo -e "${blue}→${reset} $*"; }
ok()    { echo -e "${green}✓${reset} $*"; }
warn()  { echo -e "${yellow}!${reset} $*"; }

# ── Parse arguments ──────────────────────────────────────────
if [[ $# -lt 1 ]]; then
    echo -e "${bold}Usage:${reset} create-paper <directory> [topic] [--venue <venue>] [--deep]"
    echo ""
    echo "  <directory>  Name/path for the new paper project"
    echo "  [topic]      Paper topic — starts the writing pipeline"
    echo "  --venue      Target venue format (default: generic)"
    echo "  --deep       3× research effort: 12 agents, targeted passes, more QA"
    echo ""
    echo -e "${bold}Available venues:${reset}"
    echo "  generic   Standard journal article (default)"
    echo "  ieee      IEEE conference/journal (IEEEtran, numeric citations)"
    echo "  acm       ACM conference (acmart sigconf, double-blind)"
    echo "  neurips   NeurIPS/ICML/ICLR (neurips style, 9-page limit)"
    echo "  nature    Nature family journals (Results before Methods)"
    echo "  arxiv     arXiv preprint (no limits, extended format)"
    echo "  apa       APA 7th edition (psychology/social sciences)"
    echo ""
    echo -e "${bold}Depth modes:${reset}"
    echo "  standard  5 research agents, 30-50 refs, ~\$50 (~1-4 hrs)"
    echo "  deep      12 specialized agents, 60-80 refs, targeted second"
    echo "            pass, per-section lit searches, extra Codex rounds,"
    echo "            8 QA iterations (~\$150, ~3-8 hrs)"
    echo ""
    echo "Examples:"
    echo "  create-paper my-survey \"A survey on LLM reasoning\""
    echo "  create-paper my-paper \"Protein folding\" --venue nature"
    echo "  create-paper my-paper \"Protein folding\" --venue nature --deep"
    exit 1
fi

TARGET="$1"
shift

TOPIC=""
VENUE="generic"
DEPTH="standard"

# Parse remaining args
while [[ $# -gt 0 ]]; do
    case "$1" in
        --venue|-v)
            VENUE="$2"
            shift 2
            ;;
        --deep)
            DEPTH="deep"
            shift
            ;;
        --standard)
            DEPTH="standard"
            shift
            ;;
        *)
            TOPIC="$1"
            shift
            ;;
    esac
done

if [[ -e "$TARGET" ]]; then
    echo -e "${red}✗${reset} '$TARGET' already exists." >&2
    exit 1
fi

# Validate venue
if [[ ! -f "$VENUES_DIR/$VENUE.json" ]]; then
    echo -e "${red}✗${reset} Unknown venue '$VENUE'. Available: generic, ieee, acm, neurips, nature, arxiv, apa" >&2
    exit 1
fi

# Check dependencies
for cmd in git pdflatex claude; do
    if ! command -v "$cmd" &>/dev/null; then
        echo -e "${red}✗${reset} '$cmd' is required but not found in PATH." >&2
        exit 1
    fi
done

# ── Read venue config ─────────────────────────────────────────
VENUE_FILE="$VENUES_DIR/$VENUE.json"
VENUE_NAME=$(python3 -c "import json, sys; print(json.load(open(sys.argv[1]))['name'])" "$VENUE_FILE")
VENUE_DOCCLASS=$(python3 -c "import json, sys; print(json.load(open(sys.argv[1]))['documentclass'])" "$VENUE_FILE")
VENUE_BIBSTYLE=$(python3 -c "import json, sys; print(json.load(open(sys.argv[1]))['bibliography_style'])" "$VENUE_FILE")
VENUE_ABSTRACT_LIMIT=$(python3 -c "import json, sys; print(json.load(open(sys.argv[1]))['abstract_word_limit'])" "$VENUE_FILE")
VENUE_SECTIONS=$(python3 -c "import json, sys; v=json.load(open(sys.argv[1])); print('\n'.join(v['sections']))" "$VENUE_FILE")

info "Creating ${bold}$VENUE_NAME${reset} paper in ${bold}$TARGET${reset}"

# ── Create project ────────────────────────────────────────────
mkdir -p "$TARGET"
cd "$TARGET"

# Generate main.tex from venue config
python3 - "$VENUES_DIR/$VENUE.json" <<'PYEOF'
import json, sys

with open(sys.argv[1]) as f:
    v = json.load(f)

preamble_extra = v.get("preamble_extra", [])

# Documentclass
lines = [v["documentclass"]]

# \pdfoutput=1 must appear within the first 5 lines (arXiv requirement)
early_lines = [l for l in preamble_extra if l.strip().startswith("\\pdfoutput")]
for l in early_lines:
    lines.append(l)

# Packages
for pkg in v["packages"]:
    lines.append(pkg)

# Remaining preamble_extra (float tuning, penalties, caption settings)
lines.append("")
remaining = [l for l in preamble_extra if not l.strip().startswith("\\pdfoutput")]
for l in remaining:
    lines.append(l)

# \hypersetup only when hyperref is explicitly in the packages list
has_hyperref = any("hyperref" in pkg for pkg in v["packages"])
if has_hyperref:
    lines.append("")
    lines.append("\\hypersetup{")
    lines.append("  colorlinks=true,")
    lines.append("  linkcolor=blue!70!black,")
    lines.append("  citecolor=green!50!black,")
    lines.append("  urlcolor=blue!80!black")
    lines.append("}")

lines.append("")
lines.append("\\title{Your Paper Title Here}")
lines.append("\\author{")
lines.append("  First Author\\textsuperscript{1} \\and")
lines.append("  Second Author\\textsuperscript{2} \\\\\\\\")
lines.append("  \\textsuperscript{1}Department, University \\\\\\\\")
lines.append("  \\textsuperscript{2}Department, University \\\\\\\\")
lines.append("  \\texttt{email@example.com}")
lines.append("}")
lines.append("\\date{\\today}")
lines.append("")
lines.append("\\begin{document}")
lines.append("")
lines.append("\\maketitle")
lines.append("")
lines.append("\\begin{abstract}")
lines.append("% TODO: Write abstract (limit: " + str(v["abstract_word_limit"]) + " words)")
lines.append("\\end{abstract}")
lines.append("")

for section in v["sections"]:
    lines.append("\\section{" + section + "}")
    lines.append("% TODO: Write " + section + " section")
    lines.append("")

lines.append("\\bibliographystyle{" + v["bibliography_style"] + "}")
lines.append("\\bibliography{references}")
lines.append("")
lines.append("\\end{document}")

with open("main.tex", "w") as f:
    f.write("\n".join(lines) + "\n")
PYEOF
ok "main.tex generated ($VENUE_NAME format)"

# Copy per-project files
cp "$TEMPLATE_DIR/references.bib" .
cp "$TEMPLATE_DIR/gitignore" .gitignore
mkdir -p .claude figures attachments research/sources provenance/cuts
cp "$TEMPLATE_DIR/claude/settings.local.json" .claude/

# Symlink shared files back to the research-agent template.
# When the template is updated, every project sees the change instantly.
ln -s "$TEMPLATE_DIR/claude/CLAUDE.md" .claude/CLAUDE.md
ln -s "$TEMPLATE_DIR/claude/commands" .claude/commands
ln -s "$TEMPLATE_DIR/claude/pipeline" .claude/pipeline
ln -s "$TEMPLATE_DIR/scripts" scripts

# Copy venue config for reference
cp "$VENUES_DIR/$VENUE.json" .venue.json
ok "Template files linked"

# Generate .paper.json config
python3 - "$TOPIC" "$VENUE" "$DEPTH" <<'PYEOF'
import json, sys, secrets, re
from pathlib import Path
topic, venue, depth = sys.argv[1], sys.argv[2], sys.argv[3]
# Derive namespace from directory name + random suffix for OpenSearch isolation
dir_name = Path(".").resolve().name
safe_name = re.sub(r"[^a-z0-9-]", "-", dir_name.lower()).strip("-")[:40]
namespace = f"{safe_name}-{secrets.token_hex(2)}"
config = {
    "topic": topic,
    "venue": venue,
    "depth": depth,
    "knowledge_namespace": namespace,
    "model": "claude-opus-4-6",
    "max_revisions": 3,
    "authors": [
        {
            "name": "First Author",
            "affiliation": "Department, University",
            "email": "author@example.com",
            "orcid": ""
        }
    ],
    "keywords": [],
    "funding": "",
    "conflicts": "",
    "data_availability": "",
    "code_availability": ""
}
json.dump(config, open(".paper.json", "w"), indent=2)
PYEOF
ok "Paper config written (.paper.json)"

# Initialize git
git init -q
ok "Git initialized"

# Add scientific skills submodule (shallow clone for speed)
info "Cloning 177 scientific skills (shallow)..."
git submodule add --depth 1 "$SKILLS_REPO" vendor/claude-scientific-skills 2>&1 | grep -v "^$"
ok "Skills submodule added"

# Symlink skills into .claude/skills
ln -s "$(pwd)/vendor/claude-scientific-skills/scientific-skills" .claude/skills
ok "Skills linked to .claude/skills"

# Set up codex-bridge if available (optional sister project)
if command -v codex-bridge &>/dev/null; then
    codex-bridge init &>/dev/null
    # Merge the codex .mcp.json into our project (it creates its own)
    ok "Codex Bridge configured (adversarial AI reviewer)"
else
    info "codex-bridge not found — skipping (install for adversarial AI review)"
fi

# Set up Praxis scientific analysis toolkit (optional)
info "Setting up Praxis scientific analysis toolkit..."
git submodule add --depth 1 "$PRAXIS_REPO" vendor/praxis 2>&1 | grep -v "^$"
if [[ -d vendor/praxis ]]; then
    # Symlink Praxis as a skill
    ln -s "$(pwd)/vendor/praxis" .claude/skills/praxis
    # Install Praxis Python dependencies
    if python3 -m pip install -q numpy scipy pandas matplotlib lmfit peakutils openpyxl uncertainties 2>/dev/null; then
        ok "Praxis installed (50+ characterisation techniques, 9 journal styles)"
    else
        ok "Praxis linked (run 'pip install -r vendor/praxis/requirements.txt' to enable analysis)"
    fi
else
    warn "Praxis clone failed — skipping (figures and analysis still work via matplotlib)"
fi

# Initial commit (skip GPG signing — this is a local bootstrap commit in a fresh repo)
git add -A
git -c commit.gpgsign=false commit -q -m "Initial paper project ($VENUE_NAME format)"
ok "Initial commit created"

# Verify LaTeX compiles
info "Verifying LaTeX compilation..."
if latexmk -pdf -interaction=nonstopmode main.tex &>/dev/null; then
    ok "LaTeX compiles successfully"
    latexmk -c &>/dev/null
else
    warn "LaTeX compilation had issues (you can fix them with /compile)"
fi

# ── Summary ───────────────────────────────────────────────────
echo ""
echo -e "${bold}Paper project ready!${reset}"
echo ""
echo "  Project:  $(pwd)"
echo "  Venue:    $VENUE_NAME"
echo "  Depth:    $DEPTH"
echo ""

if [[ "$DEPTH" == "deep" ]]; then
    echo -e "  ${bold}Deep mode enabled:${reset}"
    echo "    12 specialized research agents (vs 5)"
    echo "    60-80 reference target (vs 30-50)"
    echo "    Thesis-informed second research pass"
    echo "    Per-section literature deep-dives"
    echo "    8 QA iterations with extra Codex rounds"
    echo "    Estimated: 3-8 hours, ~\$150"
else
    echo "  Standard mode: 5 agents, 30-50 refs, ~1-4 hrs, ~\$50"
    echo "  Add ${bold}--deep${reset} for 3x research effort"
fi
echo ""

echo -e "${bold}Commands:${reset}"
echo "  /write-paper <topic>   Autonomous pipeline (1-4 hrs, journal quality)"
echo "  /preview-pipeline      Show what the pipeline will do (dry run)"
echo "  /init <topic>          Quick single-pass generation"
echo ""
echo "  /search-literature     Find relevant papers"
echo "  /add-citation          Add a BibTeX reference"
echo "  /ingest-papers         Import PDFs from attachments/"
echo "  /cite-network          Citation coverage analysis"
echo "  /ask <question>        Query research artifacts for answers"
echo ""
echo "  /outline <section>     Draft section outline"
echo "  /revise-section        Rewrite with feedback"
echo "  /analyze-data          Statistical analysis and figure generation"
echo "  /praxis-analyze        Domain-specific analysis via Praxis toolkit"
echo ""
echo "  /compile               Build PDF"
echo "  /review                Manuscript quality review"
echo "  /check-consistency     Find notation/terminology inconsistencies"
echo "  /audit-claims          Flag overclaims and unsupported statements"
echo "  /check-citations       Verify every citation is real"
echo "  /novelty-check         Verify contribution hasn't been published"
echo "  /codex-review          Adversarial AI review via Codex"
echo "  /de-ai-polish          Remove AI writing patterns"
echo "  /auto [N]             Autonomous improvement iterations on finished paper"
echo "  /provenance            Query the provenance audit trail"
echo "  /knowledge             Query the knowledge graph"
echo "  /health                Check project setup and dependencies"
echo "  /status                Progress dashboard"
echo ""
echo "  /archive               Bundle research artifacts for browsing"
echo "  /prepare-submission    Generate submission package"
echo "  /lay-summary           Plain-language summary and elevator pitch"
echo "  /clean                 Remove build artifacts"
echo ""

# ── Launch ────────────────────────────────────────────────────
if [[ -n "$TOPIC" ]]; then
    echo -e "${bold}Ready to write!${reset}"
    echo ""
    echo "  ${bold}Autonomous${reset} (recommended — agent-based, runs for hours):"
    echo "    cd $(pwd) && write-paper"
    echo ""
    echo "  ${bold}Interactive${reset} (you guide each step manually):"
    echo "    cd $(pwd) && claude"
    echo ""
    read -p "Launch autonomous pipeline now? [Y/n] " -n 1 -r
    echo ""
    if [[ ! $REPLY =~ ^[Nn]$ ]]; then
        exec "$SCRIPT_DIR/write-paper"
    fi
else
    info "Launch when ready:"
    echo ""
    echo "  ${bold}Autonomous:${reset}  cd $(pwd) && write-paper \"your topic\""
    echo "  ${bold}Interactive:${reset} cd $(pwd) && claude"
fi
